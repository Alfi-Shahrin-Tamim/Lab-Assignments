           (a == p && e == p && i == p) ||
           (d == p && e == p && f == p) ||
           (b == p && e == p && h == p) ||
           (g == p && e == p && c == p) ||
           (c == p && f == p && i == p) ||
           (g == p && h == p && i == p);
}           

