#include <stdio.h>

void current(char a, char b, char c, char d, char e, char f, char g, char h, char i){

    printf("%c | %c | %c\n", a, b, c);
    printf("---------\n");
    printf("%c | %c | %c\n", d, e, f);
    printf("---------\n");
    printf("%c | %c | %c\n", g, h, i);    
}

int win(char p, char a, char b, char c, char d, char e, char f, char g, char h, char i){

    return (a == p && b == p && c == p) ||
           (a == p && d == p && g == p) ||
           (a == p && e == p && i == p) ||
           (d == p && e == p && f == p) ||
           (b == p && e == p && h == p) ||
           (g == p && e == p && c == p) ||
           (c == p && f == p && i == p) ||
           (g == p && h == p && i == p);
}           

